# Required — the app raises ValueError at import time if this is missing.
OPENAI_API_KEY=sk-...

# Optional — LLM call tracing/observability via Langfuse (langfuse.openai.OpenAI
# wrapper). If unset, tracing calls are effectively no-ops; the app still runs.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
